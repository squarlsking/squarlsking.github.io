---
import Layout from '../layouts/Layout.astro';
import SiteHeaderNav from '../components/SiteHeaderNav.astro';
import { nowWorking } from '../data/now-working';
import { getNotes } from '../lib/notes';
import image1 from '../assets/image_1.jpg';
import image2 from '../assets/image_2.jpg';

const notes = await getNotes();

const articleItems = notes.map((item) => ({
	title: item.title,
	excerpt: item.summary,
	date: item.date.toLocaleDateString('en-US'),
	href: item.url
}));

const socialLinks = [
	{ label: 'GitHub', href: 'https://github.com/squarlsking?tab=repositories' },
	{ label: 'Bilibili', href: 'https://space.bilibili.com/3546385267820867?spm_id_from=333.1007.0.0' }
] as const;
---

<Layout title="Yuxuan Gu | Personal Homepage & Blog" description="A computer science undergraduate learning mathematics.">
	<section class="intro-screen flex min-h-[100svh] items-center justify-center px-6">
		<div class="text-center">
			<p class="intro-kicker mb-5 text-xs uppercase tracking-[0.35em]">curated homepage</p>
			<h1 class="bilingual-title intro-title mx-auto text-4xl font-bold md:text-6xl">
				<span class="line-en">Hello World</span>
				<span class="line-zh">Welcome</span>
			</h1>
			<p class="intro-sub mt-8 text-sm md:text-base">Scroll down to enter my digital gallery.</p>
		</div>
	</section>

	<main id="home-content" class="editorial-home mx-auto flex w-full max-w-7xl flex-col gap-6 px-4 py-8 md:px-8 md:py-12">
		<SiteHeaderNav current="home" />

		<section class="ed-grid">
			<div class="ed-top-left ed-rule">
				<h1 class="ed-name">Yuxuan Gu</h1>
				<p class="ed-identity-sub">
					<span>A computer science undergraduate</span>
					<span>currently learning mathematics.</span>
				</p>
				<div class="ed-social-links">
					{socialLinks.map((link) => (
						<a href={link.href} target="_blank" rel="noreferrer" class="ed-social-link">{link.label}</a>
					))}
				</div>
				<section class="ed-ledger">
					<div class="ed-ledger-head">
						<h2 class="ed-title ed-ledger-title">Week Plan</h2>
						<span class="ed-mono">WEEK {nowWorking.weekLabel}</span>
					</div>
					<ul>
						{nowWorking.items.map((item) => (
							<li class="ed-ledger-item">
								<span class={`ed-check ${item.done ? 'is-done' : ''}`}></span>
								<span>{item.label}</span>
							</li>
						))}
					</ul>
				</section>
			</div>

			<div class="ed-top-right ed-rule">
				<img src={image1.src} alt="Primary abstract architectural visual" class="ed-anchor-image" />
			</div>

			<div class="ed-bottom-main ed-rule">
				<div class="ed-feed-layout">
					<img src={image2.src} alt="Secondary accent visual" class="ed-accent-s" />
					<div class="ed-feed-content">
						<p class="ed-mono ed-feed-meta">CS, NOVEL, GAME, LOGIC SYSTEMS</p>
						<h2 class="ed-title ed-feed-heading">Article Feed</h2>
						<div class="ed-feed-list">
							{articleItems.map((item) => (
								<a href={item.href} class="ed-feed-item">
									<p class="ed-mono ed-feed-date">{item.date}</p>
									<h3 class="ed-feed-title">{item.title}</h3>
									<p class="ed-feed-excerpt">{item.excerpt}</p>
								</a>
							))}
						</div>
					</div>
				</div>
			</div>

			<aside class="ed-research-row ed-rule">
				<p class="ed-mono">ONGOING RESEARCH</p>
				<h2 class="ed-title">Research Inquiry</h2>
				<p class="ed-mono ed-placeholder">Future scholastic inquiries to follow...</p>
			</aside>
			</div>
		</section>

	</main>

	<script>
		const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		const introSeenKey = 'intro-seen-v1';

		if (window.location.hash === '#home-content') {
			history.replaceState(null, '', window.location.pathname + window.location.search);
		}

		window.scrollTo({ top: 0, behavior: 'auto' });

		if (!prefersReducedMotion) {
			document.body.classList.add('intro-lock');
		}

		const hasSeenIntro = localStorage.getItem(introSeenKey) === '1';
		const holdDuration = prefersReducedMotion ? 0 : hasSeenIntro ? 800 : 2600;

		if (!hasSeenIntro) {
			localStorage.setItem(introSeenKey, '1');
		}

		window.setTimeout(() => {
			document.body.classList.remove('intro-lock');
		}, holdDuration);
	</script>
</Layout>
