---
import Layout from '../layouts/Layout.astro';
import SiteHeaderNav from '../components/SiteHeaderNav.astro';
import PostCard from '../components/log/PostCard.astro';
import SocialIconRow from '../components/log/SocialIconRow.astro';
import { getNotes } from '../lib/notes';
import imgHead from '../assets/imgHead.png';

const notes = await getNotes();
const homePreview = notes.slice(0, 6);
const postCount = notes.length;
---

<Layout
	title="Yuxuan Gu | Personal Homepage & Blog"
	description="Computer science undergraduate documenting learning notes and side projects."
	htmlClass="home-entry"
>
	<section class="intro-screen home-snap-intro flex min-h-[100dvh] flex-col" aria-label="Welcome">
		<div class="flex flex-1 flex-col items-center justify-center px-6 py-16 md:px-10">
			<h1 class="home-intro-splash">Hello! Welcome to Yuxuan’s Log!</h1>
		</div>
		<div class="home-scroll-cue" aria-hidden="true">
			<span>Scroll</span>
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M12 5v14M5 12l7 7 7-7"></path>
			</svg>
		</div>
	</section>

	<main id="home-main" class="home-snap-main log-page-bg">
		<div class="log-shell pb-16 pt-2">
			<SiteHeaderNav current="posts" />

			<header class="log-hero">
				<div class="log-hero-panel log-hero-panel--minimal">
					<div class="log-hero-main">
						<h1 class="log-hero-heading">
							<span class="log-hero-hello">Hello!</span>
							<span class="log-hero-title-line">Welcome to Yuxuan’s Log</span>
						</h1>
						<p class="log-hero-lead">
							Hi, I’m Yuxuan (顾宇煊). I write learning notes on CS and math here—often drafted with AI, always
							edited by me. If anything reads awkward, that’s still on me. Thanks for visiting.
						</p>
						<div class="log-hero-social log-hero-social--minimal">
							<SocialIconRow />
						</div>
					</div>

					<aside class="log-hero-aside" aria-label="Profile">
						<img src={imgHead.src} alt="Yuxuan Gu" class="log-hero-avatar" width={imgHead.width} height={imgHead.height} />
						<p class="log-hero-aside-name">Yuxuan Gu</p>
						<p class="log-hero-aside-meta">{postCount} posts · CS · Math</p>
					</aside>
				</div>
			</header>

			<div class="log-home-feed">
				<p class="log-section-label">Recent writing</p>
				<section class="log-post-stack" aria-label="Recent posts">
					{homePreview.map((note) => (
						<PostCard note={note} />
					))}
				</section>

				<p class="log-more-link">
					<a href="/posts">View all posts →</a>
				</p>
			</div>
		</div>
	</main>

	<script>
		if (window.location.hash === '#home-main') {
			history.replaceState(null, '', window.location.pathname + window.location.search);
		}
	</script>
</Layout>
