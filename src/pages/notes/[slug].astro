---
import Layout from '../../layouts/Layout.astro';
import SiteHeaderNav from '../../components/SiteHeaderNav.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const notes = await getCollection('notes');

  return notes.map((note) => ({
    params: { slug: note.id },
    props: { note }
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);
---

<Layout title={`${note.data.title} | 顾宇煊`} description={note.data.summary}>
  <main class="mx-auto w-full max-w-4xl px-4 py-10 md:px-6">
    <SiteHeaderNav />

    <article class="glass mt-6 rounded-3xl p-6 md:p-8">
      <header class="mb-6 border-b border-slate-200/70 pb-5">
        <p class="mb-2 text-xs font-medium uppercase tracking-[0.12em] text-slate-500">{note.data.kind}</p>
        <h1 class="text-3xl font-bold leading-tight text-slate-900">{note.data.title}</h1>
        <p class="mt-2 text-sm text-slate-600">{note.data.summary}</p>
        <p class="mt-2 text-xs text-slate-400">{note.data.date.toLocaleDateString('zh-CN')}</p>
      </header>

      <section class="prose prose-slate max-w-none prose-headings:font-semibold prose-a:text-sky-700 prose-code:text-slate-700">
        <Content />
      </section>
    </article>
  </main>
</Layout>
