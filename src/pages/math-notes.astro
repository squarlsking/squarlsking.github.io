---
import Layout from '../layouts/Layout.astro';
import SiteHeaderNav from '../components/SiteHeaderNav.astro';
import { getNotes } from '../lib/notes';

const notes = await getNotes('course');
---

<Layout title="数学笔记 | 顾宇煊" description="数学笔记与推导整理">
  <main class="mx-auto w-full max-w-6xl px-4 py-10 md:px-6">
    <SiteHeaderNav current="math" />

    <section class="glass rounded-3xl p-6 md:p-8">
      <p class="editorial-kicker">Math Archive</p>
      <h1 class="gallery-heading text-3xl font-semibold text-slate-900 md:text-4xl">数学笔记</h1>
      <p class="mt-2 text-slate-600">把线代、概率与离散数学的核心公式压缩成易查阅的记录。</p>

      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {notes.map((item) => (
          <a href={item.url} class="editorial-card block rounded-2xl border border-[#dfdbcf]/80 bg-white/86 p-4">
            <article>
              <p class="text-[11px] uppercase tracking-[0.14em] text-slate-500">Note Entry</p>
              <h2 class="mt-1 text-lg font-semibold leading-snug text-slate-900">{item.title}</h2>
              <p class="mt-2 text-sm leading-relaxed text-slate-600">{item.summary}</p>
              <p class="mt-3 text-xs uppercase tracking-[0.1em] text-[#9a7f4b]">{item.date.toLocaleDateString('zh-CN')}</p>
            </article>
          </a>
        ))}
      </div>
    </section>
  </main>
</Layout>
