---
import Layout from '../layouts/Layout.astro';
import SiteHeaderNav from '../components/SiteHeaderNav.astro';
import { getNotes } from '../lib/notes';

const notes = await getNotes('course');
---

<Layout title="数学笔记 | 顾宇煊" description="数学笔记与推导整理">
  <main class="mx-auto w-full max-w-6xl px-4 py-10 md:px-6">
    <SiteHeaderNav current="math" />

    <section class="glass rounded-3xl p-6 md:p-8">
      <h1 class="text-3xl font-bold text-slate-900">数学笔记</h1>
      <p class="mt-2 text-slate-600">把线代、概率与离散数学的核心公式压缩成易查阅的记录。</p>

      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {notes.map((item) => (
          <a href={item.url} class="block rounded-2xl border border-white/75 bg-white/80 p-4 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
            <article>
              <h2 class="text-lg font-semibold text-slate-900">{item.title}</h2>
              <p class="mt-1 text-sm text-slate-600">{item.summary}</p>
              <p class="mt-2 text-xs text-slate-400">{item.date.toLocaleDateString('zh-CN')}</p>
            </article>
          </a>
        ))}
      </div>
    </section>
  </main>
</Layout>
