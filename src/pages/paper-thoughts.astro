---
import Layout from '../layouts/Layout.astro';
import SiteHeaderNav from '../components/SiteHeaderNav.astro';
import { getNotes } from '../lib/notes';

const papers = await getNotes('paper');
---

<Layout title="论文思考 | 顾宇煊" description="论文阅读与思考摘要">
  <main class="mx-auto w-full max-w-6xl px-4 py-10 md:px-6">
    <SiteHeaderNav current="paper" />

    <section class="glass rounded-3xl p-6 md:p-8">
      <p class="editorial-kicker">Paper Digest</p>
      <h1 class="gallery-heading text-3xl font-semibold text-slate-900 md:text-4xl">论文思考</h1>
      <p class="mt-2 text-slate-600">关注模型结构、训练策略与可复现实验结论。</p>

      <div class="mt-6 space-y-4">
        {papers.map((item) => (
          <article class="editorial-card rounded-2xl border border-[#dfdbcf]/80 bg-white/88 p-4">
            <a href={item.url} class="block">
              <p class="text-[11px] uppercase tracking-[0.14em] text-slate-500">Reading Memo</p>
              <h2 class="mt-1 text-lg font-semibold leading-snug text-slate-900">{item.title}</h2>
              <p class="mt-2 text-sm leading-relaxed text-slate-600">{item.summary}</p>
            </a>
            <div class="mt-3 flex items-center gap-3 text-xs">
              <span class="uppercase tracking-[0.1em] text-[#9a7f4b]">{item.date.toLocaleDateString('zh-CN')}</span>
              {item.link && <a href={item.link} class="text-slate-500 underline decoration-slate-300 underline-offset-4 hover:text-slate-700" target="_blank" rel="noreferrer">原文链接</a>}
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
</Layout>
