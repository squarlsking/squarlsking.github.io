---
/** Social links: GitHub, Bilibili, Zhihu, CSDN — stroke icons + word marks where clearer */
---

<div class="log-social-icons">
	<a
		href="https://github.com/squarlsking?tab=repositories"
		class="log-social-icon"
		target="_blank"
		rel="noreferrer"
		aria-label="GitHub"
		title="GitHub"
	>
		<svg
			class="log-social-icon__svg"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="1.75"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true"
		>
			<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
		</svg>
	</a>
	<a
		href="https://space.bilibili.com/3546385267820867?spm_id_from=333.1007.0.0"
		class="log-social-icon"
		target="_blank"
		rel="noreferrer"
		aria-label="Bilibili"
		title="Bilibili"
	>
		<svg
			class="log-social-icon__svg"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="1.75"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true"
		>
			<path d="M8 3h8l3 3v15H5V6l3-3Z" />
			<path d="M5 9h14" />
			<path d="M10 13h4v4h-4z" />
		</svg>
	</a>
	<a
		href="https://www.zhihu.com/people/song-shu-da-wang-69"
		class="log-social-icon log-social-icon--word"
		target="_blank"
		rel="noreferrer"
		aria-label="知乎"
		title="知乎"
	>
		<span class="log-social-icon__word" aria-hidden="true">知乎</span>
	</a>
	<a
		href="https://blog.csdn.net/2301_79763311?spm=1000.2115.3001.10640"
		class="log-social-icon log-social-icon--word"
		target="_blank"
		rel="noreferrer"
		aria-label="CSDN 博客"
		title="CSDN 博客"
	>
		<span class="log-social-icon__word log-social-icon__word--csdn" aria-hidden="true">CSDN</span>
	</a>
</div>
