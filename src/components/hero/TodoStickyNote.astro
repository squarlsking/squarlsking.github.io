---
interface Props {
  items: Array<{ label: string; done?: boolean }>;
  weekLabel?: string;
}

const { items, weekLabel } = Astro.props as Props;
---

<article class="paper-note relative rounded-[1.35rem] border border-[#d8d4c8]/90 bg-[#fdfbf4] p-4 shadow-[0_10px_26px_rgba(31,41,55,0.08)] ring-1 ring-white/70 rotate-[0.5deg] md:rounded-[1.6rem] md:p-5 md:rotate-[1deg]">
  <span class="absolute -top-3 left-1/2 h-5 w-20 -translate-x-1/2 rotate-[3deg] rounded-sm border border-[#d7d1c0]/80 bg-[#f7f2e6]/78 md:h-6 md:w-24"></span>
  <span class="absolute right-5 top-4 h-3.5 w-3.5 rounded-full bg-[#d8d1bf] shadow-[inset_0_1px_2px_rgba(255,255,255,0.6),0_2px_5px_rgba(100,116,139,0.16)]"></span>
  <span class="absolute left-5 top-3 h-2 w-10 rotate-[-10deg] rounded-sm bg-[#e8dcc2]/72"></span>

  <div class="mb-3 flex items-center justify-between gap-3">
    <div>
      <h3 class="gallery-heading text-base font-semibold text-slate-900 md:text-lg">Now Working On</h3>
      <p class="text-[10px] uppercase tracking-[0.16em] text-slate-500">Weekly Ledger</p>
    </div>
    {weekLabel && <span class="rounded-full border border-slate-300 bg-white px-2 py-0.5 text-[10px] text-slate-500 md:text-[11px]">{weekLabel}</span>}
  </div>
  <ul class="space-y-2.5">
    {items.map((item) => (
      <li class="flex items-center gap-2 text-xs text-slate-700 md:gap-2.5 md:text-sm">
        <span class={`inline-flex h-4 w-4 items-center justify-center rounded border text-[10px] md:h-[18px] md:w-[18px] md:text-xs ${item.done ? 'border-slate-500 bg-slate-500 text-white' : 'border-slate-400 bg-white'}`}>
          {item.done ? '✓' : ''}
        </span>
        <span class={item.done ? 'line-through decoration-slate-500/70' : ''}>{item.label}</span>
      </li>
    ))}
  </ul>
</article>
