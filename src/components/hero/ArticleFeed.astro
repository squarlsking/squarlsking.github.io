---
interface ArticleItem {
  title: string;
  excerpt: string;
  date: string;
  toneClass: string;
  href: string;
}

interface Props {
  items: ArticleItem[];
}

const { items } = Astro.props as Props;
const placeholderCount = Math.max(0, 4 - items.length);
---

<section class="rounded-3xl border border-slate-200/70 bg-white/70 p-3 md:p-5 shadow-[0_18px_45px_rgba(15,23,42,0.09)] md:min-h-[38rem]">
  <div class="mb-3 flex items-center justify-between">
    <h3 class="text-lg font-bold text-slate-900 md:text-xl">Article Feed</h3>
    <span class="text-[11px] font-medium text-slate-600 md:text-xs">Latest Notes</span>
  </div>

  <div class="space-y-3">
    {items.map((item) => (
      <a href={item.href} class="block rounded-2xl border border-white/80 bg-white/85 p-2.5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md md:p-3">
        <article>
          <div class="flex gap-2.5 md:gap-3">
            <div class={`h-16 w-20 shrink-0 rounded-xl border border-slate-200 md:h-[72px] md:w-24 ${item.toneClass}`}></div>
            <div class="min-w-0 space-y-1">
              <h4 class="line-clamp-2 text-sm font-semibold text-slate-900 md:text-base">{item.title}</h4>
              <p class="line-clamp-2 text-xs text-slate-600 md:text-sm">{item.excerpt}</p>
              <p class="text-[11px] text-slate-400 md:text-xs">{item.date}</p>
            </div>
          </div>
        </article>
      </a>
    ))}

    {Array.from({ length: placeholderCount }).map(() => (
      <article class="rounded-2xl border border-dashed border-slate-200 bg-white/55 p-2.5 md:p-3">
        <div class="flex gap-2.5 md:gap-3">
          <div class="h-16 w-20 shrink-0 rounded-xl border border-slate-200/80 bg-slate-100/70 md:h-[72px] md:w-24"></div>
          <div class="min-w-0 flex-1 space-y-2 pt-1">
            <div class="h-3 w-2/3 rounded bg-slate-200/80"></div>
            <div class="h-3 w-full rounded bg-slate-100"></div>
            <div class="h-3 w-3/4 rounded bg-slate-100"></div>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>
