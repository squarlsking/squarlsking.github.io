---
interface ArticleItem {
  title: string;
  excerpt: string;
  date: string;
  toneClass: string;
  href: string;
}

interface Props {
  items: ArticleItem[];
}

const { items } = Astro.props as Props;
const placeholderCount = Math.max(0, 4 - items.length);
---

<section class="paper-panel rounded-3xl border border-[#d8d4c8]/80 bg-[#fffdf8]/78 p-3 md:p-5 shadow-[0_12px_32px_rgba(31,41,55,0.08)] md:min-h-[38rem]">
  <div class="mb-3 flex items-center justify-between">
    <h3 class="gallery-heading text-xl font-semibold text-slate-900 md:text-2xl">Article Feed</h3>
    <span class="text-[11px] font-medium uppercase tracking-[0.14em] text-slate-500 md:text-xs">Latest Notes</span>
  </div>

  <div class="space-y-3">
    {items.map((item) => (
      <a href={item.href} class="editorial-card block rounded-2xl border border-[#e1ded4] bg-[#fffdfa]/92 p-2.5 md:p-3">
        <article>
          <div class="flex gap-2.5 md:gap-3">
            <div class={`h-16 w-20 shrink-0 rounded-xl border border-slate-200 md:h-[72px] md:w-24 ${item.toneClass}`}></div>
            <div class="min-w-0 space-y-1">
              <h4 class="line-clamp-2 text-base font-semibold leading-snug text-slate-900">{item.title}</h4>
              <p class="text-[11px] uppercase tracking-[0.1em] text-[#9a7f4b] md:text-xs">{item.date}</p>
              <p class="line-clamp-2 text-xs leading-relaxed text-slate-600 md:text-sm">{item.excerpt}</p>
            </div>
          </div>
        </article>
      </a>
    ))}

    {Array.from({ length: placeholderCount }).map(() => (
      <article class="rounded-2xl border border-dashed border-[#ddd9cd] bg-[#f8f6ef]/72 p-2.5 md:p-3">
        <div class="flex gap-2.5 md:gap-3">
          <div class="h-16 w-20 shrink-0 rounded-xl border border-slate-200/80 bg-slate-100/70 md:h-[72px] md:w-24"></div>
          <div class="min-w-0 flex-1 space-y-2 pt-1">
            <div class="h-3 w-2/3 rounded bg-slate-200/80"></div>
            <div class="h-3 w-full rounded bg-slate-100"></div>
            <div class="h-3 w-3/4 rounded bg-slate-100"></div>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>
