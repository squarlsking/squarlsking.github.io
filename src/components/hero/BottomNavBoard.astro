---
interface Props {
  current?: 'posts' | 'campus';
}

const { current } = Astro.props as Props;

const navItems = [
  { key: 'posts', label: '文章', href: '/posts' },
  { key: 'campus', label: '校园指南', href: '/campus-life' }
] as const;
---

<section class="rounded-2xl border border-emerald-100/80 bg-white/75 p-3 shadow-[0_10px_26px_rgba(15,23,42,0.08)]">
  <div class="grid gap-2 sm:grid-cols-2">
    {navItems.map((item) => (
      <a
        href={item.href}
        class={`rounded-xl border px-3 py-3 text-sm font-medium transition ${current === item.key ? 'border-emerald-200 bg-emerald-50/80 text-emerald-800' : 'border-white/70 bg-white text-slate-700 hover:bg-emerald-50'}`}
      >
        {item.label}
      </a>
    ))}
  </div>
</section>
