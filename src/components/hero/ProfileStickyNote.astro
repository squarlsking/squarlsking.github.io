---
interface Props {
  name: string;
  bio: string;
  avatarSrc: string;
  socialLinks: Array<{ key: 'bilibili' | 'github'; label: string; href: string }>;
}

const { name, bio, avatarSrc, socialLinks } = Astro.props as Props;
---

<article class="relative mx-auto w-full max-w-[28rem] rounded-[1.5rem] border border-slate-200 bg-white p-4 shadow-[0_14px_32px_rgba(15,23,42,0.12)] ring-1 ring-white/70 md:rounded-[1.8rem] md:p-6">
  <span class="absolute -top-3 left-1/2 h-5 w-20 -translate-x-1/2 rotate-[-6deg] rounded-sm border border-slate-200/70 bg-white/75 md:h-6 md:w-24"></span>
  <span class="absolute right-5 top-4 h-3.5 w-3.5 rounded-full bg-sky-200 shadow-[inset_0_1px_2px_rgba(255,255,255,0.7),0_2px_6px_rgba(71,85,105,0.28)]"></span>

  <div class="flex flex-col items-center text-center">
    <div class="mb-3 mt-2 flex h-28 w-28 items-center justify-center rounded-full border-4 border-white bg-slate-100 p-1.5 shadow-[0_10px_24px_rgba(15,23,42,0.12)] md:mb-4 md:mt-3 md:h-36 md:w-36">
      <img
        src={avatarSrc}
        alt="顾宇煊头像"
        class="h-full w-full rounded-full object-cover"
        onerror="this.onerror=null;this.src='/avatar.svg';"
      />
    </div>

    <h2 class="text-3xl font-bold leading-none text-slate-900 md:text-4xl" style="font-family: 'Ma Shan Zheng', cursive;">{name}</h2>
    <p class="mt-2 text-xs leading-relaxed text-slate-600 md:text-sm">{bio}</p>

    <div class="mt-4 flex items-center gap-2.5 md:mt-5">
      {socialLinks.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noreferrer"
          class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-700 transition hover:-translate-y-0.5 hover:border-slate-300 hover:text-slate-900 md:h-10 md:w-10"
          aria-label={link.label}
          title={link.label}
        >
          {link.key === 'bilibili' ? (
            <svg viewBox="0 0 1024 1024" class="h-5 w-5" fill="currentColor" aria-hidden="true">
              <path d="M800.64 209.344h-105.6l49.152-56.32a33.792 33.792 0 1 0-50.88-44.544L614.4 199.04a33.408 33.408 0 0 0-6.4 10.304H416a33.408 33.408 0 0 0-6.4-10.304l-78.912-90.56a33.792 33.792 0 0 0-50.88 44.544l49.152 56.32H223.36C157.376 209.344 104 262.72 104 328.704v385.536C104 780.224 157.376 833.6 223.36 833.6h577.28C866.624 833.6 920 780.224 920 714.24V328.704c0-65.984-53.376-119.36-119.36-119.36z m52.096 504.896c0 28.8-23.296 52.096-52.096 52.096H223.36c-28.8 0-52.096-23.296-52.096-52.096V328.704c0-28.8 23.296-52.096 52.096-52.096h577.28c28.8 0 52.096 23.296 52.096 52.096v385.536z"></path>
              <path d="M352.192 387.2a33.6 33.6 0 0 0-33.6 33.6v209.28a33.6 33.6 0 1 0 67.2 0V420.8a33.6 33.6 0 0 0-33.6-33.6zm319.616 0a33.6 33.6 0 0 0-33.6 33.6v209.28a33.6 33.6 0 1 0 67.2 0V420.8a33.6 33.6 0 0 0-33.6-33.6z"></path>
            </svg>
          ) : (
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
              <path d="M12 .296C5.373.296 0 5.67 0 12.296c0 5.303 3.438 9.8 8.207 11.388.6.111.793-.26.793-.577v-2.234c-3.338.726-4.042-1.416-4.042-1.416-.546-1.386-1.334-1.755-1.334-1.755-1.09-.745.083-.729.083-.729 1.205.084 1.84 1.237 1.84 1.237 1.07 1.833 2.807 1.304 3.492.997.108-.775.418-1.304.76-1.604-2.665-.304-5.466-1.333-5.466-5.93 0-1.311.47-2.382 1.236-3.222-.125-.304-.536-1.527.117-3.183 0 0 1.008-.322 3.3 1.23a11.48 11.48 0 0 1 3.003-.404c1.018.005 2.045.137 3.003.404 2.292-1.552 3.298-1.23 3.298-1.23.655 1.656.244 2.88.12 3.183.77.84 1.235 1.91 1.235 3.222 0 4.609-2.805 5.624-5.479 5.921.43.372.815 1.103.815 2.222v3.293c0 .32.19.694.8.576C20.565 22.09 24 17.593 24 12.296 24 5.67 18.627.296 12 .296z"></path>
            </svg>
          )}
        </a>
      ))}
    </div>
  </div>
</article>
